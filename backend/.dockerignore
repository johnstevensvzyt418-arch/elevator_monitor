# ============================================================
# .dockerignore — 多阶段构建：源码需要打入构建上下文
# ============================================================

# IDE
.idea/
*.iml
.vscode/

# 日志
logs/
*.log

# Git
.git/
.gitignore

# 临时文件
*.tmp
*.bak

# Maven target 目录（Docker 内会重新编译）
target/

# IDE & 临时文件
.apt_generated
.classpath
.factorypath
.project
.settings/
.idea/
*.iml
*.log

# Git
.git/
.gitignore

# 文档 & 图示（非必需）
*.pu
*.md
image/

# 演示模块
demo/

# OS 临时文件
.DS_Store
Thumbs.db
